{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/entities/**/*.ts",
    "src/entities/**/*.tsx",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/infrastructure/**/*.ts",
    "src/infrastructure/**/*.tsx",
    "src/server/**/*.ts",
    "src/server/**/*.tsx",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "src/views/**/*.ts",
    "src/views/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
